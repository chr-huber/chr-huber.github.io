data = merge %>% filter(name == "investment")
) +
geom_line(
aes(x = Period, y = value, color = name, linetype = name),
data = merge %>% filter(name != "investment")
) +
theme_bw() +
theme(
legend.position = "bottom"
) +
ylab("Price") +
scale_fill_manual(name = "", labels = c("Investment"), values = c(diverging_hcl(5, palette = "Berlin")[1])) +
scale_color_manual(name = "", labels = c("Forecast", "Price"), , values = c(diverging_hcl(5, palette = "Berlin")[c(1, 3, 5)])) +
scale_linetype_discrete(name = "", labels = c("Forecast (median)", "Forecast (mean)", "Price")) +
scale_y_continuous(
name = "Price",
sec.axis = sec_axis(~./coef, name="Investment")
)
# UPDATING ---------------------------------------------------------------------
data <- read.csv('../experiments_software/otree_ch-tupdt-jvi/updt/static/updt/Data2.csv')
prices <- data %>%
filter(
ID == 18
) %>%
select(
Period,
Price
)
updating <- read.csv('../experiments_data/updt_2022-11-15.csv')
investment <- updating %>%
group_by(participant.code) %>%
mutate(
path = mean(player.treatmentpath, na.rm=TRUE)
) %>%
filter(
path == 2
) %>%
ungroup() %>%
group_by(
subsession.round_number
) %>%
summarise(
investment = sum(player.investment, na.rm=TRUE),
forecast = mean(player.forecast, na.rm=TRUE)
) %>%
rename(
Period = subsession.round_number
)
merge <-
left_join(
prices,
investment,
by = c("Period")
) %>%
pivot_longer(
cols = Price:forecast_mean
)
